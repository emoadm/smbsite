    "ioredis": "5.10.1",
    "lucide-react": "0.469.0",
    "next": "15.3.9",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "4.11.0",
    "payload": "3.84.1",
    "pg": "^8.20.0",
    "pino": "10.3.1",
