# ============================================================
# SMBsite — Environment template (commit this; never commit .env)
# Copy to .env.local for development; production secrets via fly secrets
# ============================================================

# --- Auth.js v5 (D-02) ---
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Neon Postgres (Frankfurt eu-central-1) ---
# DATABASE_URL = pooled (PgBouncer) for app queries
# DIRECT_URL   = direct (non-pooled) for migrations & Payload (Pitfall C)
DATABASE_URL=
DIRECT_URL=

# --- Payload CMS ---
PAYLOAD_SECRET=
# PAYLOAD_DATABASE_URL must equal DIRECT_URL (RESEARCH § Drizzle vs Payload)
PAYLOAD_DATABASE_URL=

# --- Upstash Redis (rate limit + BullMQ broker; eu-west-1) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# ioredis URL form (rediss://) for BullMQ — Pitfall E
UPSTASH_REDIS_URL=

# --- Brevo transactional email ---
BREVO_API_KEY=
EMAIL_FROM_TRANSACTIONAL=no-reply@auth.<sender-domain>

# --- Cloudflare Turnstile (D-05) ---
# Test keys (RESEARCH § Playwright Testing of Turnstile lines 1233-1237):
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Sentry EU (Frankfurt — DSN must end .de.sentry.io per Pitfall G) ---
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Better Stack EU log aggregator (D-21) ---
BETTERSTACK_SOURCE_TOKEN=
LOG_LEVEL=info

# --- Plausible analytics (cookie-free) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- HMAC key for OTP token hashing (Pitfall K) ---
# 32+ random bytes hex; can equal AUTH_SECRET in dev but should differ in prod
OTP_HMAC_KEY=

# --- CookieYes (D-20 — cookie consent banner) ---
NEXT_PUBLIC_COOKIEYES_SITE_KEY=

# --- MaxMind GeoLite2 (Phase 2.1 D-02) ---
# License key used at Docker BUILD time only. Set via Fly build-secret
# (`fly secrets set MAXMIND_LICENSE_KEY=<key> -a smbsite-prod`) AND GitHub
# Actions repo secret named `MAXMIND_LICENSE_KEY`. The key is NOT needed at
# runtime — the builder downloads the .mmdb file and bakes it into the image.
MAXMIND_LICENSE_KEY=

# Phase 2.1 — override path to the GeoLite2 mmdb file. Defaults to
# `${cwd}/GeoLite2-City.mmdb`. Override only for local dev or unit tests.
GEOIP_DB_PATH=
